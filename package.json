{
  "name": "web-ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.4.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "publish:animated-tabs": "npm publish --workspace @web-ui/animated-tabs --access public"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
