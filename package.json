{
  "name": "web-ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.4.1",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:playground": "npm run dev --workspace animated-tabs-playground",
    "dev:icons": "npm run dev --workspace @stemui/icons",
    "dev:icons:playground": "node ./scripts/dev-icons-playground.mjs",
    "build:playground": "npm run build --workspace animated-tabs-playground",
    "preview:playground": "npm run preview --workspace animated-tabs-playground",
    "dev:animated-tabs": "npm run dev:playground",
    "build:animated-tabs-preview": "npm run build:playground",
    "preview:animated-tabs": "npm run preview:playground",
    "build:icons": "npm run build --workspace @stemui/icons",
    "build:icons:incremental": "npm run build:incremental --workspace @stemui/icons",
    "version:icons:patch": "npm version patch --workspace @stemui/icons --no-git-tag-version",
    "version:icons:minor": "npm version minor --workspace @stemui/icons --no-git-tag-version",
    "version:icons:major": "npm version major --workspace @stemui/icons --no-git-tag-version",
    "publish:icons": "node ./scripts/publish-workspace.mjs @stemui/icons --bump patch",
    "publish:icons:manual": "node ./scripts/publish-workspace.mjs @stemui/icons --manual",
    "version:animated-tabs:patch": "npm version patch --workspace @stemui/animated-tabs --no-git-tag-version",
    "version:animated-tabs:minor": "npm version minor --workspace @stemui/animated-tabs --no-git-tag-version",
    "version:animated-tabs:major": "npm version major --workspace @stemui/animated-tabs --no-git-tag-version",
    "publish:animated-tabs": "node ./scripts/publish-workspace.mjs @stemui/animated-tabs --bump patch",
    "publish:animated-tabs:manual": "node ./scripts/publish-workspace.mjs @stemui/animated-tabs --manual"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
