{
  "name": "web-ui",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.4.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "version:animated-tabs:patch": "npm version patch --workspace @stemui/animated-tabs --no-git-tag-version",
    "version:animated-tabs:minor": "npm version minor --workspace @stemui/animated-tabs --no-git-tag-version",
    "version:animated-tabs:major": "npm version major --workspace @stemui/animated-tabs --no-git-tag-version",
    "publish:animated-tabs": "npm run version:animated-tabs:patch && npm publish --workspace @stemui/animated-tabs --access public",
    "publish:animated-tabs:manual": "npm publish --workspace @stemui/animated-tabs --access public"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
